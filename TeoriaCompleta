def pulisci_telefono(cliente):
    # Prendo il telefono (es. "+55 (12) 3923-5555")
    tel = cliente.phone
    
    # Se per caso il cliente non ha il telefono (è None), restituisco uno 0 per non far crashare il programma
    if tel is None:
        return 0
        
    # Sostituisco i simboli strani con niente ("")
    tel_pulito = tel.replace("+", "").replace(" ", "").replace("(", "").replace(")", "").replace("-", "")
    
    # Ora che ho "551239235555", posso convertirlo in numero!
    return int(tel_pulito)

